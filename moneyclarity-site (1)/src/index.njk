---
layout: base.njk
title: Home
---

<section class="hero">
  <h1>Master your money with confidence.</h1>

  <p class="hero-sub">
    EveryDayMoneyLab helps people make smarter financial decisions through
    practical, easy-to-follow guides on budgeting, saving, investing,
    debt management, credit cards, retirement planning, taxes,
    side hustles, and building long-term wealth—without hype,
    gimmicks, or get-rich-quick promises.
  </p>

  <a class="btn" href="/blog/">Start Learning →</a>
</section>

<section class="latest">
  <h2>Latest Posts</h2>

  <ul class="post-list">
    {% for post in collections.posts %}
    <li>
      <a href="{{ post.url }}">
        <span class="post-list-title">{{ post.data.title }}</span>
        <span class="post-list-date">{{ post.data.date | readableDate }}</span>
      </a>

      {% if post.data.description %}
      <p>{{ post.data.description }}</p>
      {% endif %}
    </li>
    {% endfor %}
  </ul>
</section>

<section id="subscribe" class="subscribe">
  <h2>Get EveryDayMoneyLab in your inbox</h2>

  <p>
    Actionable money tips, practical guides, and new articles.
    No spam. Unsubscribe anytime.
  </p>

  <form name="subscribe" method="POST" data-netlify="true" netlify-honeypot="bot-field">
    <input type="hidden" name="form-name" value="subscribe" />

    <p class="hidden">
      <label>Don't fill this out:
        <input name="bot-field" />
      </label>
    </p>

    <input
      type="email"
      name="email"
      placeholder="you@example.com"
      required
    >

    <button class="btn" type="submit">
      Subscribe
    </button>
  </form>
</section>

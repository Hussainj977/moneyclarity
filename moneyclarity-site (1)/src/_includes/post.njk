layout: base.njk
---
<article class="post">
  <p class="post-date">{{ date | readableDate }}</p>
  <h1>{{ title }}</h1>
  {% if description %}<p class="post-lede">{{ description }}</p>{% endif %}
  <div class="post-body">
    {{ content | safe }}
  </div>
</article>

<div class="post-cta">
  <p>Get new everydaymoneylab posts by email — no spam, unsubscribe anytime.</p>
  <a class="btn" href="/#subscribe">Subscribe</a>
</div>

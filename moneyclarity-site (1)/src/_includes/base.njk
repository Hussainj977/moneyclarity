<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <meta name="google-site-verification" content="mxOyT0lzntq4Ya2We3drPEVrD1kGyE51z4bRMBZNAsg" />

  <title>{% if title %}{{ title }} | {{ site.title }}{% else %}{{ site.title }} — {{ site.description }}{% endif %}</title>

  <meta name="description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}">

  <link rel="stylesheet" href="/css/style.css">

  <meta property="og:title" content="{% if title %}{{ title }}{% else %}{{ site.title }}{% endif %}">
  <meta property="og:description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}">
  <meta property="og:type" content="website">
</head>

<body>

<header class="site-header">
  <nav class="wrap">

    <a class="brand" href="/">everydaymoneylab</a>

    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/guides/">Guides</a>
      <a href="/blog/">Blog</a>
      <a href="/about/">About</a>
    </div>

  </nav>
</header>

<main class="wrap">
  {{ content | safe }}
</main>

<footer class="site-footer">
  <div class="wrap">
    <p>&copy; {{ currentYear }} everydaymoneylab by {{ site.author }}. Built for clarity, not clicks.</p>
  </div>
</footer>

</body>
</html>
